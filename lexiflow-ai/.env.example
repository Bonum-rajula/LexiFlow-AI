# .env.example (Commit this)
# --------------------------
# LLM Provider
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Embedding Model
EMBEDDING_MODEL=text-embedding-3-small

# Vector Database (Chroma)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=lexiflow_docs

# Application
LOG_LEVEL=INFO
MAX_CHUNK_SIZE=512
CHUNK_OVERLAP=50